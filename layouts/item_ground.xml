<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    style="@style/KreedaCard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvGroundName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ground Name"
            android:textStyle="bold"
            android:textColor="@color/dark_slate"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvGroundAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Address"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvGroundSports"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sports: Cricket · Football"
            android:textColor="@color/mint_green"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvGroundHours"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="06:00 AM – 10:00 PM"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
